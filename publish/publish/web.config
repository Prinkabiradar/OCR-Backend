<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules>
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <httpProtocol>
        <customHeaders>
          <!--
            REMOVE all IIS-level CORS headers.
            ASP.NET Core middleware sets these correctly.
            Having both causes the "multiple values" CORS browser error.
          -->
          <remove name="Access-Control-Allow-Origin" />
          <remove name="Access-Control-Allow-Credentials" />
          <remove name="Access-Control-Allow-Methods" />
          <remove name="Access-Control-Allow-Headers" />
          <remove name="Access-Control-Expose-Headers" />
          <remove name="Vary" />
        </customHeaders>
      </httpProtocol>
      <!--
        REMOVE the IIS rewrite rule for OPTIONS preflight.
        ASP.NET Core's UseCors() middleware handles preflight
        requests correctly. The IIS rule was intercepting OPTIONS
        requests BEFORE they reached ASP.NET Core, returning a
        204 with no CORS headers — causing preflight to fail.
      -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="524288000" />
        </requestFiltering>
      </security>
      <aspNetCore processPath="dotnet" arguments=".\OCR-BACKEND.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="GEMINI_API_KEY" value="AIzaSyBCEY_SarPqwcI47ZAq9QmGAJfwItOfNp4" />
          <environmentVariable name="DIGITALOCEAN_SPACES_ACCESS_KEY" value="DO801HLWYVZAZGFP42LG" />
          <environmentVariable name="DIGITALOCEAN_SPACES_SECRET_KEY" value="kvrnKgzJGhmD2YnvPGvZINQq/bfznD/RFmlGiKB8lxg" />
          <environmentVariable name="DIGITALOCEAN_SPACES_NAME" value="hda-ocr-storage" />
          <environmentVariable name="DIGITALOCEAN_SPACES_REGION" value="sgp1" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
