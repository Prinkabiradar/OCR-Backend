# Digital Ocean Spaces Configuration
# Copy this file to .env.local (macOS/Linux) or load manually (Windows)
# WARNING: NEVER commit this file to Git!
# Add .env.local to .gitignore

# Your Digital Ocean Access Key
# Get this from: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_SPACES_ACCESS_KEY=your_access_key_here

# Your Digital Ocean Secret Key
# Get this from: https://cloud.digitalocean.com/account/api/spaces (Access Keys section)
DIGITALOCEAN_SPACES_SECRET_KEY=your_secret_key_here

# Your Space Name
# Create a Space at: https://cloud.digitalocean.com/spaces
# Example: ocr-documents
DIGITALOCEAN_SPACES_NAME=your-space-name

# Digital Ocean Region (default: nyc3)
# Available regions: nyc3, sfo3, sgp1, lon1, ams3, blr1, tor1
DIGITALOCEAN_SPACES_REGION=nyc3

# Optional: Fallback Models for Gemini API
# GEMINI_FALLBACK_MODELS=gemini-3.1-pro-preview,gemini-2.5-flash

# Optional: Add other configuration here
# DATABASE_CONNECTION_STRING=...
# JWT_SECRET=...
